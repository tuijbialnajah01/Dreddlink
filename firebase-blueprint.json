{
  "entities": {
    "Group": {
      "title": "Community Group",
      "description": "Represents a community group listing.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the group"
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the group avatar/image"
        },
        "joinLink": {
          "type": "string",
          "description": "The URL to join the group"
        },
        "isPublic": {
          "type": "boolean",
          "description": "Whether the group is visible to the public or hidden"
        },
        "category": {
          "type": "string",
          "description": "The category the group belongs to"
        },
        "createdAt": {
          "type": "string",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "description": "Last updated timestamp"
        }
      },
      "required": ["name", "imageUrl", "joinLink", "isPublic", "category", "createdAt", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Represents an admin user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The email of the admin"
        },
        "createdAt": {
          "type": "string",
          "description": "Creation timestamp"
        }
      },
      "required": ["email", "createdAt"]
    },
    "Broadcast": {
      "title": "Broadcast",
      "description": "Represents a global broadcast announcement.",
      "type": "object",
      "properties": {
        "imageUrl": {
          "type": "string",
          "description": "Image URL for the broadcast"
        },
        "link": {
          "type": "string",
          "description": "Hyperlink for the broadcast action"
        },
        "expiresAt": {
          "type": "string",
          "description": "Expiration timestamp"
        },
        "createdAt": {
          "type": "string",
          "description": "Creation timestamp"
        }
      },
      "required": ["imageUrl", "link", "expiresAt", "createdAt"]
    },
    "Visit": {
      "title": "Visit",
      "description": "Represents a single website visit.",
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "description": "Timestamp of the visit"
        }
      },
      "required": ["timestamp"]
    }
  },
  "firestore": {
    "/groups/{groupId}": {
      "schema": {
        "$ref": "#/entities/Group"
      },
      "description": "Collection of groups"
    },
    "/admins/{adminId}": {
      "schema": {
        "$ref": "#/entities/Admin"
      },
      "description": "Collection of admin users."
    },
    "/broadcasts/{broadcastId}": {
      "schema": {
        "$ref": "#/entities/Broadcast"
      },
      "description": "Collection of broadcasts."
    },
    "/visits/{visitId}": {
      "schema": {
        "$ref": "#/entities/Visit"
      },
      "description": "Collection of visits."
    }
  }
}
